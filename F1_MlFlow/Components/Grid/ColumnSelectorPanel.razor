@using F1_MlFlow.Models.Grid

<div class="column-selector card shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <strong>Colunas</strong>
            <button class="btn btn-sm btn-outline-secondary" @onclick="OnClose">Fechar</button>
        </div>

        <input class="form-control form-control-sm mb-2" name="grid-column-search" placeholder="Buscar coluna" @oninput="OnSearchChanged" />

        <div class="d-flex flex-wrap gap-2 mb-2">
            <button class="btn btn-sm btn-outline-primary" @onclick="ShowAll">Mostrar todas</button>
            <button class="btn btn-sm btn-outline-primary" @onclick="HideAll">Ocultar todas</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ResetDefaults">Restaurar padrão</button>
        </div>

        <div class="column-list">
            @foreach (var column in FilteredColumns)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="col-@column.Key" checked="@column.Visible" @onchange="(args) => ToggleColumn(column, args)" id="col-@column.Key" />
                    <label class="form-check-label" for="col-@column.Key">@column.Title</label>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<GridColumnDefinition> Columns { get; set; } = Array.Empty<GridColumnDefinition>();
    [Parameter] public IReadOnlyDictionary<string, bool> DefaultVisibility { get; set; } = new Dictionary<string, bool>();
    [Parameter] public EventCallback OnColumnsChanged { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private string _search = string.Empty;

    private IEnumerable<GridColumnDefinition> FilteredColumns => string.IsNullOrWhiteSpace(_search)
        ? Columns
        : Columns.Where(column => column.Title.Contains(_search, StringComparison.OrdinalIgnoreCase));

    private void OnSearchChanged(ChangeEventArgs args)
    {
        _search = args.Value?.ToString() ?? string.Empty;
    }

    private async Task ToggleColumn(GridColumnDefinition column, ChangeEventArgs args)
    {
        if (args.Value is bool isChecked)
        {
            column.Visible = isChecked;
        }
        else if (bool.TryParse(args.Value?.ToString(), out var parsed))
        {
            column.Visible = parsed;
        }

        await OnColumnsChanged.InvokeAsync();
    }

    private async Task ShowAll()
    {
        foreach (var column in Columns)
        {
            column.Visible = true;
        }

        await OnColumnsChanged.InvokeAsync();
    }

    private async Task HideAll()
    {
        foreach (var column in Columns)
        {
            column.Visible = false;
        }

        await OnColumnsChanged.InvokeAsync();
    }

    private async Task ResetDefaults()
    {
        foreach (var column in Columns)
        {
            if (DefaultVisibility.TryGetValue(column.Key, out var isVisible))
            {
                column.Visible = isVisible;
            }
        }

        await OnColumnsChanged.InvokeAsync();
    }
}
