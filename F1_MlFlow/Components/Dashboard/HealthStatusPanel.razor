@using F1_MlFlow.Models.Health

<div class="card shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <strong>@Title</strong>
            @if (Status is not null)
            {
                <span class="badge @GetStatusClass(Status.Status)">@Status.Status</span>
            }
        </div>

        @if (Status is not null)
        {
            <div class="text-muted small">@Status.Message</div>
            <div class="text-muted small">Latência: @(Status.LatencyMs?.ToString("0") ?? "-") ms</div>
            <div class="text-muted small">Atualizado: @Status.CheckedAt.ToLocalTime().ToString("g")</div>
        }

        @if (Dependencies?.Count > 0)
        {
            <div class="mt-3">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Dependência</th>
                            <th>Status</th>
                            <th>Latência</th>
                            <th>Mensagem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dependency in Dependencies)
                        {
                            <tr>
                                <td>@dependency.Name</td>
                                <td><span class="badge @GetStatusClass(dependency.Status)">@dependency.Status</span></td>
                                <td>@(dependency.LatencyMs?.ToString("0") ?? "-") ms</td>
                                <td>@dependency.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Health";
    [Parameter] public HealthStatusDto? Status { get; set; }
    [Parameter] public IReadOnlyList<HealthDependencyDto>? Dependencies { get; set; }

    private static string GetStatusClass(string? status)
    {
        return status?.ToLowerInvariant() switch
        {
            "ok" => "bg-success",
            "healthy" => "bg-success",
            "degraded" => "bg-warning",
            "warning" => "bg-warning",
            "fail" => "bg-danger",
            "failed" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}
