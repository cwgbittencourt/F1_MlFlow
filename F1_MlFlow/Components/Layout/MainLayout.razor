@inherits LayoutComponentBase
@inject NavigationLoadingState NavLoading
@inject NavigationManager NavManager
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="d-flex gap-3 align-items-center">
                <a href="docs">Documentação</a>
            </div>
        </div>

        <article class="content px-4">
            <LoadingBanner IsVisible="@NavLoading.IsActive" />
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
@code {
    protected override void OnInitialized()
    {
        NavLoading.OnChange += HandleNavLoadingChanged;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (NavLoading.IsActive &&
            !string.IsNullOrWhiteSpace(NavLoading.TargetUri) &&
            string.Equals(NavManager.Uri, NavLoading.TargetUri, StringComparison.OrdinalIgnoreCase))
        {
            NavLoading.Stop();
        }

        return Task.CompletedTask;
    }

    private void HandleNavLoadingChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavLoading.OnChange -= HandleNavLoadingChanged;
    }
}






